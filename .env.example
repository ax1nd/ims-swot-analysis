# Google AI Studio (Gemini) API key for KUTTI chatbot
# Get one at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_api_key_here

# Firebase (for Google Sign-In — only @ritchennai.edu.in allowed)
# Create a project at https://console.firebase.google.com, enable Authentication > Sign-in method > Google
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# MySQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ims_user
DB_PASSWORD=ims_password
DB_NAME=ims_db

# Backend API Configuration
VITE_API_URL=http://127.0.0.1:5001
